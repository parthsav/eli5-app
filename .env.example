# OpenAI API key (used by FastAPI backend in api/index.py)
OPENAI_API_KEY=sk-replace-me

# Optional: override the backend URL the Next.js frontend talks to.
# In production on Vercel, leave this unset so the frontend uses the
# same-origin /api/chat route. For local dev, point at your uvicorn server.
# NEXT_PUBLIC_API_URL=http://localhost:8000
